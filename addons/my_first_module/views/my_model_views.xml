<odoo>
    <!-- List view -->
    <record id="view_my_first_model_list" model="ir.ui.view">
        <field name="name">my.first.model.list</field>
        <field name="model">my.first.model</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="description"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <!-- Form view -->
    <record id="view_my_first_model_form" model="ir.ui.view">
        <field name="name">my.first.model.form</field>
        <field name="model">my.first.model</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="description"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Menu action -->
    <record id="action_my_first_model" model="ir.actions.act_window">
        <field name="name">My First Model</field>
        <field name="res_model">my.first.model</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Menu item -->
    <menuitem id="menu_my_first_module"
              name="My First Module"
              action="action_my_first_model"
              sequence="100"/>
</odoo>
