<odoo>
    <record id="view_position_list" model="ir.ui.view">
        <field name="name">hr.simple.position.list</field>
        <field name="model">hr.simple.position</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="department_id"/>
            </list>
        </field>
    </record>

    <record id="view_position_form" model="ir.ui.view">
        <field name="name">hr.simple.position.form</field>
        <field name="model">hr.simple.position</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="department_id"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_position" model="ir.actions.act_window">
        <field name="name">Positions</field>
        <field name="res_model">hr.simple.position</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
