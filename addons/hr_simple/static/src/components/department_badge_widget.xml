<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="hr_simple.DepartmentBadgeWidget">
        <span t-if="displayName"
              t-attf-style="
                background-color: #{color};
                color: white;
                padding: 3px 10px;
                border-radius: 12px;
                font-size: 12px;
                font-weight: bold;
              "
              t-out="displayName"/>
        <span t-else="">—</span>
    </t>
</templates>

